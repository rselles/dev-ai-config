#!/usr/bin/env bash
# gfetch вЂ” fetch and summarise a URL via Gemini CLI, log token savings.
#
# Usage: gfetch <url> [extraction prompt]
#   stdout: Gemini's summary (pipe to context.md or let Claude read it)
#   stderr: per-call savings line with rawв†’summary delta
#   ~/.gemini-gain.log: CSV row appended
#
# Environment:
#   GEMINI_GAIN_LOG  вЂ” override log file path (default: ~/.gemini-gain.log)

set -uo pipefail

if [ $# -eq 0 ]; then
  echo "Usage: gfetch <url> [extraction prompt]" >&2
  exit 1
fi

url="$1"
shift
extraction="${*:-summarise the key content}"
logfile="${GEMINI_GAIN_LOG:-$HOME/.gemini-gain.log}"

# в”Ђв”Ђ Baseline: raw page byte count в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
raw_bytes=$(curl -sL --max-time 15 "$url" 2>/dev/null | wc -c) || raw_bytes=0
raw_tok=$(( raw_bytes / 4 ))

# в”Ђв”Ђ Call Gemini в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
prompt="Fetch ${url} and ${extraction}"
json=$(gemini -p "$prompt" --output-format json 2>/dev/null) || {
  echo "[gfetch] gemini call failed" >&2
  exit 1
}

# в”Ђв”Ђ Extract summary and token counts в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Try jq first; fall back to crude grep/sed if jq is absent or fails.
summary=$(echo "$json" | jq -r '.response // empty' 2>/dev/null) || summary=""
input_tok=$(echo "$json" | jq -r '[.stats.models[].tokens.input] | add // empty' 2>/dev/null) || input_tok=""
output_tok=$(echo "$json" | jq -r '[.stats.models[].tokens.candidates] | add // empty' 2>/dev/null) || output_tok=""

if [ -z "$summary" ]; then
  summary=$(echo "$json" | grep -o '"response": *"[^"]*"' | sed 's/"response": *"//;s/"$//')
fi

# в”Ђв”Ђ Compute summary token estimate в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
summary_bytes=$(printf '%s' "$summary" | wc -c)
summary_tok=$(( summary_bytes / 4 ))

# в”Ђв”Ђ Write summary to stdout в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
printf '%s\n' "$summary"

# в”Ђв”Ђ Print savings line to stderr в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [ "$raw_tok" -gt 0 ] && [ "$summary_tok" -gt 0 ]; then
  saved=$(( raw_tok - summary_tok ))
  pct=$(( saved * 100 / raw_tok ))
  printf '[gfetch] %s\n         raw ~%s tok в†’ summary ~%s tok (saved ~%s, %s%%)\n' \
    "$url" "$raw_tok" "$summary_tok" "$saved" "$pct" >&2
else
  printf '[gfetch] %s\n         raw ~%s tok в†’ summary ~%s tok\n' \
    "$url" "$raw_tok" "$summary_tok" >&2
fi

# в”Ђв”Ђ Append CSV row в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
# columns (tab-separated): timestamp  mode  target  raw_tokens  summary_tokens  gemini_input_tokens  gemini_output_tokens
printf '%s\tgfetch\t%s\t%s\t%s\t%s\t%s\n' \
  "$timestamp" \
  "$url" \
  "$raw_tok" \
  "$summary_tok" \
  "${input_tok}" \
  "${output_tok}" \
  >> "$logfile"
